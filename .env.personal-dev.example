# Optional developer-owned VPS mode. This file contains routing and SSH
# metadata only; application secrets belong in PERSONAL_DEV_RUNTIME_ENV_FILE.
PERSONAL_DEV_SSH_HOST=dev-fpsmeimei
PERSONAL_DEV_USER=deploy
PERSONAL_DEV_SSH_KEY=~/.ssh/2049-personal-dev
PERSONAL_DEV_REMOTE_DIR=/opt/dev/projects/meimei-api
PERSONAL_DEV_COMPOSE_PROJECT=meimei-api-fpsmeimei
PERSONAL_DEV_RUNTIME_ENV_FILE=~/.config/goodbyeri/personal-dev/meimei-api.env

# The remote API stays on the VPS loopback interface. The local frontend
# reaches it through the tunnel service in docker-compose.web.yml.
PERSONAL_DEV_API_PORT=3100
PERSONAL_DEV_LOCAL_API_PORT=3310
PERSONAL_DEV_WEB_PORT=3002
PERSONAL_DEV_WEB_COMPOSE_PROJECT=meimei-api-personal-web
