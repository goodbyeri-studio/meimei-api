FROM alpine:3.22.1@sha256:4bcff63911fcb4448bd4fdacec207030997caf25e9bea4045fa6c8c44de311d1

RUN apk add --no-cache autossh curl openssh-client

COPY deploy/personal-dev/tunnel-entrypoint.sh /usr/local/bin/personal-dev-tunnel
RUN chmod 0755 /usr/local/bin/personal-dev-tunnel

ENTRYPOINT ["/usr/local/bin/personal-dev-tunnel"]
